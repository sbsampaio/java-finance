# Compiled class files
*.class

# Packaged artifacts (Ignore jars, wars, ears, and zips generated by your Jakarta builds)
*.jar
*.war
*.ear
*.zip

# Build folders
# Maven
target/
# Gradle
build/
.gradle/

# Weblogic specific
# (Jakarta/Java EE web applications often use specific servers for deployment)
.wlsversion

# Log files
*.log
logs/

# JVM crash logs
hs_err_pid*

# Operating System generated files
.DS_Store
Thumbs.db

# IDE configuration files
.vscode
.classpath
.project
.settings/
.metadata/
*.iml
*.iws
*.ipr
.idea/
